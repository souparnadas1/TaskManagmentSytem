@model Taskcategory

@{
    ViewData["Title"] = "Add Category";
}

<div class="row justify-content-center">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Category Entry</h5>
            </div>

            <div class="card-body">
                <form asp-controller="Category" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label text-muted">Category ID</label>
                        <input type="text" class="form-control" value="Auto generated" disabled />
                        <small class="text-muted">System generated, read-only</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">
                            Category Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Work, Personal, Shopping..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">Back</a>
                        <button type="submit" class="btn btn-primary w-100">Save Category</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}