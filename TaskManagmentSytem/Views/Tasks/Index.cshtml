@model IEnumerable<Tasks>

@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Tasks</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Task
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Task Name</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Description</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model)
                {
                    <tr>
                        <td class="text-muted">@task.Id</td>
                        <td class="fw-medium">@task.Name</td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @task.Category?.Name
                            </span>
                        </td>
                        <td class="text-muted">@task.TaskDate.ToString("dd MMM yyyy")</td>
                        <td class="text-muted">@task.TaskTime.ToString("hh:mm tt")</td>
                        <td class="text-muted">@task.TaskDescription</td>
                        <td class="text-muted">@task.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@task.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Edit
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    onclick="confirmDelete(@task.Id, '@task.Name')">
                                Delete
                            </button>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No tasks found. Click "Add Task" to create one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Delete Confirmation Modal *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="taskName"></strong>?
                This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('taskName').innerText = name;
            document.getElementById('deleteForm').action = '/Tasks/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}